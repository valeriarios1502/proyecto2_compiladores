FROM node:20-bookworm

RUN apt-get update \
  && apt-get install -y --no-install-recommends cmake g++ make \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY . .

RUN cmake -S . -B build \
  && cmake --build build --config Release \
  && cp build/Proyecto2 ./Proyecto2

WORKDIR /app/backend

RUN npm ci --omit=dev

ENV PORT=3001
EXPOSE 3001

CMD ["node", "server.js"]